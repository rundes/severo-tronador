# Supabase (service role: bypassa RLS para escribir listening_items)
SUPABASE_URL=https://yfjuxhjlcrkmjzcvgley.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Proyecto destino (default = Maipú / proyecto principal)
PROJECT_ID=00000000-0000-0000-0000-000000000001

# Cuenta de X QUEMABLE (viola ToS; puede ser baneada). Metadata de la cuenta:
X_USERNAME=
X_EMAIL=
X_PASSWORD=

# Cookies de una sesión ya logueada en el navegador (x.com → DevTools →
# Application → Cookies). El login programático de X está roto; se usa cookies.
#   auth_token: hex de ~40 chars · ct0: hex largo
X_AUTH_TOKEN=
X_CT0=

# Ritmo (lento a propósito para no gatillar rate-limit)
TWEETS_PER_HANDLE=5
DELAY_SECONDS=45
