# Severo Tronador — variables de entorno (ver PLAN.md §Variables de entorno).
# Copiar a .env.local y completar. Todo es opcional: sin credenciales, la app
# corre contra el padrón mock, con la auth deshabilitada y los conectores en
# modo simulado. Ver docs/INTEGRATIONS.md para el paso a paso de cada conector.

# ── Identidad del despliegue (genérica si se deja vacía) ───────────────────
APP_NAME=severo·tronador
ORG_NAME=el equipo de relevamiento
TERRITORY=tu territorio

# ── Auth (Google OAuth vía NextAuth) ───────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Allowlist coma-separada. Vacío = cualquier cuenta Google (solo dev).
ALLOWED_EMAILS=

# ── Google Sheets (padrón) ─────────────────────────────────────────────────
GOOGLE_SHEETS_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# JSON de la service account, codificado en base64.
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Canales (se activan al setear su key; vacío = modo mock) ───────────────
# Email (Resend). Sin key, el conector simula envíos y consume cuota igual.
RESEND_API_KEY=
RESEND_FROM=relevamiento@encuestas.tu-dominio.ar
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=
# App Secret de la Meta App (Settings → Basic → App Secret). Requerido en
# producción: el POST del webhook valida x-hub-signature-256 con HMAC-SHA256
# sobre el raw body usando esta clave.
META_WA_APP_SECRET=
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
# Clave pública (base64) del portal Telnyx para verificar la firma Ed25519 de
# los webhooks de entrega en /api/webhooks/telnyx. Sin esto el webhook rechaza
# todo con 403. Portal: Account → Keys & Credentials → Public Key.
TELNYX_PUBLIC_KEY=

# ── Persistencia (Supabase) ────────────────────────────────────────────────
# Sin estas, la app cae a stores en memoria (dev/mock); con ellas Supabase es
# la base operativa. Ver docs/INTEGRATIONS.md §Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CONFIG_MASTER_KEY=               # base64 de 32 bytes: openssl rand -base64 32
SHEETS_PRESERVATION_SHEET_ID=    # Sheet destino del espejo de preservación

# ── Cron ───────────────────────────────────────────────────────────────────
# Protege /api/cron/sheets-sync (espejo Supabase → Sheets).
CRON_SECRET=

# ── Voz (Telnyx, opcional) + listening (opcional) ──────────────────────────
TELNYX_VOICE_CONNECTION_ID=
TELNYX_VOICE_FROM=
X_API_BEARER_TOKEN=
# Handles por corrida del cron de timelines (escucha activa). Default 50.
X_TIMELINE_BATCH=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
ANTHROPIC_API_KEY=

# ── Mail @tronador.net.ar (Plan 04) ────────────────────────────────────────
# Dos backends mutuamente excluyentes (autodetectados):
#  · STALWART_*  → webmail real (crear/enviar/recibir individuales) vía JMAP.
#    Stalwart corre gratis en Oracle Cloud Always-Free (o cualquier VPS).
#  · MAIL_INBOUND_SECRET (sin Stalwart) → modo Cloudflare: solo inbound
#    (Email Worker postea replies al webhook). Sin webmail.
# Sin ninguna de las dos → modo mock. El envío MASIVO va por Resend (arriba),
# independiente de esto.
STALWART_URL=                    # ej https://mail.tronador.net.ar (gatilla modo Stalwart)
STALWART_ADMIN_TOKEN=            # admin API token para provisionar casillas
MAIL_INBOUND_SECRET=             # HMAC compartido con el Cloudflare Email Worker
MAIL_REPLIES_ENABLED=            # "1" para inyectar Reply-To replies+<token>@
MAIL_REPLIES_DOMAIN=tronador.net.ar
MAIL_REPLIES_LOCAL=replies
MAIL_REPLIES_USER=               # casilla de replies (modo Stalwart, cron poll)
MAIL_REPLIES_PASSWORD=
